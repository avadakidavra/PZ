#Дано два числа.Вывести порядковый номер меньшего числа
# Запрашиваем у пользователя два числа
num1 = int(input("Введите первое число: "))
num2 = int(input("Введите второе число: "))

# Сравниваем два числа и выводим порядковый номер меньшего
if num1 < num2:
    print("Первое число меньше")
else:
    print("Второе число меньше")
